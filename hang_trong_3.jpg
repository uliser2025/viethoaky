E:Default-MAX:1\"},{\"type\":\"SECTION\",\"code\":\"seciton-detail-chi-tiet\",\"taxonomy\":\"Detail\",\"template\":\"TEMPLATE:Article\",\"layout\":\"LAYOUT:Default\"}]}",{"primary":42},{"article":43},{"tags":44,"textToSpeechAudios":67,"authors":68,"relatedArticles":90,"category":155,"id":163,"siteId":27,"articleId":164,"originalId":164,"sub":75,"title":47,"intro":165,"content":166,"summary":165,"thumbnail":167,"represent":75,"url":14,"code":48,"priority":99,"redirect":75,"metadata":168,"keywords":170,"language":49,"description":12,"routes":12,"settings":171,"features":12,"taxonomy":12,"type":12,"layoutType":27,"contentType":27,"publicationTime":175,"isUnlisted":12,"isPublished":13,"publishedBy":12,"publishedOn":12,"expiresOn":12,"views":12,"likes":12,"rates":12,"follows":12,"shares":12,"reports":12,"comments":12,"statistics":176,"originator":12,"handlers":12,"contributors":12,"portalIds":62,"categoryId":156,"categoryIds":12,"topicIds":12,"eventIds":12,"collectionIds":12,"scoringCategoryId":12,"relations":177,"order":12,"status":63,"oldId":12,"oldUrls":12},[45],{"id":46,"siteId":27,"url":14,"title":47,"code":48,"priority":12,"language":49,"description":12,"type":12,"routes":50,"settings":58,"features":12,"taxonomy":60,"metadata":61,"views":12,"likes":12,"rates":12,"shares":12,"reports":12,"portalIds":62,"categoryIds":12,"topicIds":12,"eventIds":12,"order":12,"status":63,"createdBy":64,"createdOn":65,"updatedBy":66,"updatedOn":65},138759,"Ngũ hổ trong tranh Hàng Trống","ngu-ho-trong-tranh-hang-trong","vi",[51,54],{"portal":28,"values":52},[53],"{authority}/the-nhan/{tag}{extension}",{"portal":55,"values":56},654,[57],"{authority}/tag/{tag}{extension}",{"additions":59},{},"KTDT",{"title":12,"image":12,"favicon":12,"keywords":12,"description":12,"copyright":12,"language":12,"canonical":12,"additions":12},"349",60,9999999999,"2022-02-01T08:34:54.19",1183,[],[69],{"id":70,"siteId":27,"userId":71,"url":72,"title":73,"code":74,"priority":12,"language":49,"description":75,"type":76,"routes":77,"settings":84,"features":12,"taxonomy":60,"metadata":86,"views":12,"likes":12,"rates":12,"shares":12,"reports":12,"portalIds":62,"categoryIds":87,"topicIds":12,"eventIds":12,"order":12,"status":63,"createdBy":64,"createdOn":88,"updatedBy":89,"updatedOn":88},47,171,"/lai-tan-47.html","Lại Tấn","lai-tan-47","",2,[78,81],{"portal":28,"values":79},[80],"{authority}/tac-gia/{author}{extension}",{"portal":55,"values":82},[83],"{authority}/author/{author}{extension}",{"additions":85},{},{"additions":12},"2103","2022-01-02T20:12:08.813",1173,[91,129],{"id":92,"siteId":27,"articleId":93,"originalId":93,"sub":12,"title":94,"intro":95,"thumbnail":96,"represent":75,"url":97,"code":98,"priority":99,"type":12,"layoutType":27,"contentType":27,"publicationTime":100,"isUnlisted":101,"isPublished":13,"publishedBy":102,"publishedOn":100,"views":103,"statistics":104,"originator":102,"handlers":105,"contributors":105,"portalIds":62,"categoryId":106,"eventIds":107,"relations":108,"status":63,"category":119,"createdBy":102,"createdOn":128,"updatedBy":102,"updatedOn":128},288550,288577,"Hồi sinh tranh Tết Hàng Trống","Kinhtedothi - Một thời gian dài, tranh dân gian Hàng Trống mang bản sắc dân tộc bị lùi vào quá khứ, chỉ còn xuất hiện trong bảo tàng, di tích văn hóa. Nhưng gần đây nhờ bàn tay của giới họa sĩ và công chúng trẻ, họa tiết tranh cổ được ứng dụng vào lĩnh vực thiết kế đương đại, tranh Hàng Trống đã trở nên gần gũi hơn với đông đảo người dân.","2021/12/22/c3a16d54-6e9a-4554-b0b3-04e6d37d260f.jpg","/hoi-sinh-tranh-tet-hang-trong-408754","hoi-sinh-tranh-tet-hang-trong-408754",0,"2021-02-11T06:50:00",false,168,312,{},"168",297,"51",{"tags":109,"authors":113,"category":106,"categories":115,"events":116,"embeddedElements":118},[110,111,112],56562,56563,56564,[114],67,[28],[117],51,{},{"id":106,"siteId":27,"portalId":28,"parentId":120,"parentPath":12,"url":121,"code":122,"name":123,"priority":27,"authority":12,"language":49,"description":123,"type":76,"routes":12,"settings":124,"features":12,"taxonomy":60,"metadata":125,"isPublished":13,"publishType":27,"publishedBy":12,"publishedOn":12,"expiresOn":12,"order":127,"status":63,"createdBy":27},250,"/thoi-su/tin-tuc","thoi-su/tin-tuc","Tin tức",{},{"title":123,"keywords":123,"description":123,"language":49,"canonical":126},"tin-tuc",75,"2021-12-22T06:21:24.133",{"id":130,"siteId":27,"articleId":131,"originalId":131,"sub":12,"title":132,"intro":133,"thumbnail":134,"represent":75,"url":135,"code":136,"priority":99,"type":12,"layoutType":27,"contentType":27,"publicationTime":137,"isUnlisted":101,"isPublished":13,"publishedBy":102,"publishedOn":137,"views":138,"statistics":139,"originator":102,"handlers":105,"contributors":105,"portalIds":62,"categoryId":106,"relations":140,"status":63,"category":151,"createdBy":102,"createdOn":154,"updatedBy":102,"updatedOn":154},283367,283394,"[Ảnh] Biến tấu của dòng tranh Hàng Trống trong đời sống đương đại","Kinhtedothi - Tranh Hàng Trống đang dần bị mai một. Trước thức trạng đó, phường Hàng Trống đã phối hợp với trường Đại học Mỹ thuật Hà Nội thực hiện Dự án từ truyền thống đến truyền thống. Trước kia, tranh Hàng Trống được vẽ trên giấy dó, với dự án này tranh Hàng Trống đã được chuyển thể sang chất liệu sơn mài và lụa, với nhiều kiểu dáng khác nhau.","2021/12/22/8f7b18c7-a92f-43ab-814c-25cbe3381e98.jpg","/anh-bien-tau-cua-dong-tranh-hang-trong-trong-doi-song-duong-dai-403364","anh-bien-tau-cua-dong-tranh-hang-trong-trong-doi-song-duong-dai-403364","2020-12-03T11:44:00",993,{},{"tags":141,"authors":147,"category":106,"categories":149,"embeddedElements":150},[142,143,144,145,146],17144,33291,58255,64534,64535,[148],123,[28],{},{"id":106,"siteId":27,"portalId":28,"parentId":120,"parentPath":12,"url":121,"code":122,"name":123,"priority":27,"authority":12,"language":49,"description":123,"type":76,"routes":12,"settings":152,"features":12,"taxonomy":60,"metadata":153,"isPublished":13,"publishType":27,"publishedBy":12,"publishedOn":12,"expiresOn":12,"order":127,"status":63,"createdBy":27},{},{"title":123,"keywords":123,"description":123,"language":49,"canonical":126},"2021-12-22T18:53:51.307",{"id":156,"siteId":27,"portalId":28,"parentId":28,"parentPath":12,"url":157,"code":158,"name":159,"priority":27,"authority":12,"language":49,"description":159,"type":76,"routes":12,"settings":160,"features":12,"taxonomy":60,"metadata":161,"isPublished":13,"publishType":27,"publishedBy":12,"publishedOn":12,"expiresOn":12,"order":162,"status":63,"createdBy":27},273,"/van-hoa","van-hoa","Văn hóa",{},{"title":159,"keywords":159,"description":159,"language":49,"canonical":158},78,325643,325828,"Kinhtedothi - Trong tín ngưỡng dân gian Việt Nam, hổ là con vật có sức mạnh linh liêng. “Ông Ba mươi” đầy uy linh, quyền kính được dựng thành biểu tượng qua nhiều chất liệu tạo hình bằng gỗ, đá, vôi giấy, đất nung, tranh vẽ và có ở hầu khắp các công trình như đình, đền, miếu.","\u003Cp style=\"text-align: justify;\">\u003Cem>Tuy vậy, mẫu tranh được biết đến nhất l&agrave; ngũ hổ của phố H&agrave;ng Trống (H&agrave; Nội).\u003C/em>\u003C/p>\r\n\u003Cfigure class=\"image-wrap align-center-image\">\u003Cimg src=\"2022/02/01/tranh-ngu-ho-nghe-nhan-le-dinh-nghien-dong-a-danh-hoa.jpg\" alt=\"\" data-original=\"images/upload/2022/02/01/tranh-ngu-ho-nghe-nhan-le-dinh-nghien-dong-a-danh-hoa.jpg\" />\r\n\u003Cfigcaption class=\"image-caption\">\u003C/figcaption>\r\n\u003C/figure>\r\n\u003Cp style=\"text-align: justify;\">\u003Cstrong>H&igrave;nh tượng hổ trong văn h&oacute;a Việt\u003C/strong>\u003C/p>\r\n\u003Cp style=\"text-align: justify;\">Kh&ocirc;ng trưng tr&ecirc;n b&agrave;n thờ gia ti&ecirc;n như những bức tranh ngũ quả, tranh ngũ hổ thường treo ở b&agrave;n thờ d&agrave;nh ri&ecirc;ng cho &ldquo;&ocirc;ng Ba mươi&rdquo; tại đ&igrave;nh, đền, miếu. Theo c&aacute;c nh&agrave; nghi&ecirc;n cứu văn h&oacute;a d&acirc;n gian, một số đồng b&agrave;o d&acirc;n tộc thiểu số cũng c&oacute; tục thờ hổ, trong đ&oacute; c&oacute; người Khơ-m&uacute; ở T&acirc;y Bắc v&agrave; miền T&acirc;y Nghệ An. Một tập qu&aacute;n ăn s&acirc;u v&agrave;o tiềm thức của người Khơ-m&uacute; thuộc họ Rvai (hổ) đ&oacute; l&agrave; nghi lễ c&uacute;ng ma nh&agrave; (Hr&ocirc;igang).\u003C/p>\r\n\u003Cp style=\"text-align: justify;\">V&agrave;o dịp Tết Nguy&ecirc;n đ&aacute;n, người Khơ-m&uacute; thường diễn lại c&aacute;c động t&aacute;c của hổ, vật tổ của d&ograve;ng họ. Với quan niệm hổ l&agrave; tổ ti&ecirc;n của m&igrave;nh, người Khơ-m&uacute; thuộc họ Rvai ki&ecirc;ng kh&ocirc;ng động tay, săn bắn, giết v&agrave; ăn thịt hổ. Trong c&aacute;c hội h&egrave;, nghi lễ, người ta h&oacute;a trang giống như hổ. Khi gặp hổ chết, người Khơ-m&uacute; kh&oacute;c than thật sự như tổ ti&ecirc;n của m&igrave;nh qua đời. Người ta tin rằng khi chết đi, họ sẽ h&oacute;a th&agrave;nh kiếp hổ.\u003C/p>\r\n\u003Cp style=\"text-align: justify;\">Ở g&oacute;c đ&oacute; mỹ thuật, theo họa sĩ L&ecirc; Thiết Cương, h&igrave;nh tượng hổ đ&atilde; xuất hiện trong c&aacute;c đồ gốm thời L&yacute;, Trần hay trong c&aacute;c ng&ocirc;i đ&igrave;nh được x&acirc;y dựng từ thế kỷ XVI. Trong đ&oacute; c&oacute; thể kể đến như: Đ&igrave;nh Lỗ Hạnh (huyện Hiệp H&ograve;a, Bắc Giang) dựng năm 1576 c&oacute; một ph&ugrave; đi&ecirc;u hổ đang vờn; đ&igrave;nh Thổ Tang (huyện Vĩnh Tường, Vĩnh Ph&uacute;c) dựng từ thế kỷ XVII c&oacute; một bức chạm cảnh người đang săn hổ. Ngo&agrave;i ra, hổ cũng l&agrave; đề t&agrave;i đang trang tr&iacute; tr&ecirc;n c&aacute;c cột, k&egrave;o; mặt hổ ph&ugrave; ở c&aacute;c ch&ugrave;a hay h&igrave;nh tượng hổ chầu ở cổng c&aacute;c miếu, phủ. Trong c&aacute;c h&igrave;nh tượng đ&oacute;, hổ mang t&iacute;nh chất trấn yểm để kh&ocirc;ng cho t&agrave; ma v&agrave;o đ&igrave;nh, đền, miếu, phủ.\u003C/p>\r\n\u003Cp style=\"text-align: justify;\">\u003Cstrong>N&eacute;t văn h&oacute;a đặc sắc\u003C/strong>\u003C/p>\r\n\u003Cp style=\"text-align: justify;\">Tranh H&agrave;ng Trống xuất hiện v&agrave; thịnh h&agrave;nh muộn hơn c&aacute;c d&ograve;ng tranh kh&aacute;c. Trong c&aacute;c t&aacute;c phẩm đặc sắc của tranh H&agrave;ng Trống, kh&ocirc;ng thể kh&ocirc;ng n&oacute;i đến c&aacute;c tranh vẽ về hổ, đạt được th&agrave;nh tựu cao trong gi&aacute; trị tạo h&igrave;nh. Mặc d&ugrave; l&agrave; tranh thờ nhưng c&aacute;c nghệ nh&acirc;n đ&atilde; gợi tả được n&eacute;t sống động của lo&agrave;i hổ. Từ những d&aacute;ng hổ ngồi, hổ đứng, hổ đằng v&acirc;n, những &aacute;nh mắt, ch&ograve;m r&acirc;u, vẻ mặt của từng ch&uacute; hổ đều to&aacute;t l&ecirc;n sức sống m&atilde;nh liệt, n&eacute;t dữ dằn, hoang dại v&agrave; quyền uy của vị ch&uacute;a sơn l&acirc;m.\u003C/p>\r\n\u003Cp style=\"text-align: justify;\">Họa sĩ L&ecirc; Thiết Cương cho biết: &ldquo;Tranh H&agrave;ng Trống c&oacute; hai loại tranh hổ. Loại tranh đầu ti&ecirc;n, được nhiều người biết l&agrave; ngũ hổ. Trong tranh, 5 con hổ tượng trưng cho 5 hướng theo quan niệm &acirc;m dương ngũ h&agrave;nh. Hổ v&agrave;ng/thổ bao giờ cũng ở trung t&acirc;m tranh d&acirc;n gian H&agrave;ng Trống theo bố cục dọc. V&igrave; tất cả đều quy về thổ, mọi sự tr&ecirc;n đời kết th&uacute;c đều quay về với thổ&rdquo;.\u003C/p>\r\n\u003Cp style=\"text-align: justify;\">Theo c&aacute;c chuy&ecirc;n gia văn ho&aacute;, tr&ecirc;n đầu hổ v&agrave;ng, dưới mặt trời đỏ rực rỡ c&oacute; 7 chấm trắng l&agrave; h&igrave;nh tượng của ch&ograve;m đại h&ugrave;ng tinh. Ch&acirc;n hổ v&agrave;ng trấn l&ecirc;n một miếng ph&ugrave; c&oacute; ghi &ldquo;ph&aacute;p đại uy nỗ&rdquo;. Hai b&ecirc;n hổ v&agrave;ng, b&ecirc;n phải c&oacute; 5 thanh kiếm, b&ecirc;n tr&aacute;i c&oacute; 5 l&aacute; cờ lệnh. H&igrave;nh ảnh của cờ lệnh v&agrave; kiếm trong tranh ngũ hổ thể hiện sức mạnh của thi&ecirc;n nhi&ecirc;n trong quy luật vận động của vũ trụ v&agrave; sự tương t&aacute;c với tr&aacute;i đất. Sau hổ v&agrave;ng, hổ đen l&agrave; phương Bắc/h&agrave;nh Thuỷ; hổ đỏ l&agrave; phương Nam/h&agrave;nh Hoả; hổ xanh l&agrave; phương Đ&ocirc;ng/h&agrave;nh Mộc; hổ trắng l&agrave; phương T&acirc;y/h&agrave;nh Kim. Do đ&oacute;, khi thờ ngũ hổ l&agrave; thờ được to&agrave;n bộ &acirc;m dương ngũ h&agrave;nh, mang t&iacute;nh chất trấn yểm v&igrave; hổ l&agrave; sức mạnh, linh thi&ecirc;ng.\u003C/p>\r\n\u003Cp style=\"text-align: justify;\">Tuy nhi&ecirc;n, theo họa sĩ L&ecirc; Thiết Cương, rất &iacute;t khi người ta thấy b&agrave;n thờ ngũ hổ ở tư gia. B&agrave;n thờ tư gia chủ yếu l&agrave; thờ bạch hổ - hổ trắng. V&igrave; bạch hổ l&agrave; h&agrave;nh kim, kim trong &acirc;m dương ngũ h&agrave;nh hiểu theo nghĩa t&iacute;ch cực với những người kinh doanh l&agrave; tiền t&agrave;i. Muốn thờ bạch hổ, người thờ phải lễ v&agrave;o ng&agrave;y Rằm v&agrave; m&ugrave;ng Một. Kh&aacute;c với m&acirc;m lễ th&ocirc;ng thường, lễ d&acirc;ng bạch hổ l&agrave; rượu trắng, hoa trắng, thịt sống, trứng sống, gạo. Giờ lễ bao giờ cũng v&agrave;o giờ Dậu (17 - 19 giờ) v&igrave; l&uacute;c đ&oacute; kh&iacute; Kim mạnh nhất.\u003C/p>\r\n\u003Cp style=\"text-align: justify;\">Đi dọc theo con phố H&agrave;ng Trống giờ đ&acirc;y chỉ thấy san s&aacute;t những qu&aacute;n x&aacute; sang trọng, tấp nập những cửa h&agrave;ng đ&egrave;n lồng bằng lụa, bằng giấy. Hỏi ở đ&acirc;u b&aacute;n tranh H&agrave;ng Trống kh&ocirc;ng, cũng đều nhận được c&aacute;i lắc đầu. Nơi c&ograve;n s&oacute;t lại duy nhất về tranh H&agrave;ng Trống l&agrave; tư gia của nghệ nh&acirc;n L&ecirc; Đ&igrave;nh Nghi&ecirc;n (ở phố Cửa Đ&ocirc;ng, H&agrave; Nội).\u003C/p>\r\n\u003Cp style=\"text-align: justify;\">Chia sẻ về thực tế n&agrave;y, họa sĩ L&ecirc; Thiết Cương cho hay: &ldquo;Tranh bạch hổ vẫn được b&aacute;n ở phố H&agrave;ng M&atilde;. Điều n&agrave;y cho thấy, t&iacute;n ngưỡng thờ tranh hổ vẫn c&oacute; trong đời sống hiện nay. Nhưng v&igrave; t&acirc;n tiến hơn, rất &iacute;t khi ch&uacute;ng ta l&ecirc;n phố H&agrave;ng M&atilde; mua được tranh d&acirc;n gian H&agrave;ng Trống vẽ tay m&agrave; chủ yếu l&agrave; tranh in&rdquo;.\u003C/p>","2022/02/01/tranh-ngu-ho-nghe-nhan-le-dinh-nghien-dong-a-danh-hoa.jpg",{"title":169,"image":167,"favicon":12,"keywords":170,"description":165,"copyright":12,"language":49,"canonical":12,"additions":12},"Ngũ hổ trong tranh Hàng Trống ","Ngũ hổ trong tranh Hàng Trống trong tín ngưỡng dân gian Việt Nam, tín ngưỡng dân gian Việt Nam trong Ngũ hổ trong tranh Hàng Trống, tín ngưỡng dân gian Việt Nam, Ngũ hổ trong tranh Hàng Trống ",{"preview":27,"showThumbnail":12,"disableAds":101,"hiddenMode":12,"constraint":12,"interactions":172,"additions":173,"updateSetting":174,"interactionConfirm":12},{"like":13,"rate":13,"share":13,"comment":101},{"allowAds":101,"showVideoAsAvatar":101},{"updateVersion":12,"isAutoUpdate":12,"isForceUpdate":12},"2022-02-01T08:34:53.983",{},{"tags":178,"authors":179,"relatedArticles":180,"category":156,"categories":181,"embeddedElements":182},[46],[70],[131,93],[28],{},"Silent","{\"categories\":[261,2088,252,2042,251,256,257,268,249,264,255,273,260,253,254,272,258,250,2041,248],\"primaryCategory\":349,\"navigation\":{\"navigationTop\":\"component-navigation-top-trang-chu\",\"navigationBottom\":\"\"},\"placeholders\":{\"placeholderTop\":\"\",\"placeholderPopup\":\"\",\"placeholderSapo\":[486],\"placeholderLeftContent\":[489],\"placeholderFooterContent\":[487],\"placeholderCenterContent\":[488],\"placeholderThreeQuarterContent\":[502]}}",[186,190,194,198,203,208,212,216,220,224,229,233,238,242,247,251,254,258,262,267,271,275,280,282,287,291,295,299,303,307,311,314,318,322,326,330,334,338,342,346,350,354,358,361,365,368,372,376,379,383,387,391,395,399,403,406,410,414,418,422,426,430,434,438,442,446,450,451,455,459,463,467,471,475,479,483,487,490,493,497,501,505,509,513,517,521,522,526,530,534,538,542,546,550,554,558,561,565,569,573,577,581,584,588,591,595,599],{"id":187,"parentId":28,"url":188,"name":189},2088,"/luat-thu-do","Luật Thủ đô",{"id":191,"parentId":28,"url":192,"name":193},252,"/do-thi","Đô thị",{"id":195,"parentId":120,"url":196,"name":197},2092,"/thoi-su/huong-toi-ky-n