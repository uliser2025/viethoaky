nableExclusion":12,"enableAdvertising":12,"additions":705},[618],{"MAX":620},{"id":707,"code":708,"taxonomy":664,"settings":709},1989,"collection_category_details_ktdt",{"label":710,"template":711,"isOutside":101,"dataQueries":712,"dataResults":714,"dataExclusions":905,"dataLoading":609,"useExclusion":13,"enableExclusion":12,"enableAdvertising":12,"additions":907},"Cùng chuyên mục","Article_Category",[713],"Get[Article] Top[5] Filters[Category:{CategoryId}&Portals:349] Sort[PublicationTime-]",{"E177B68AC41572AF67F9FA23B565BCDC":715},[716,750,794,827,873],{"id":717,"siteId":27,"sub":75,"title":718,"intro":719,"thumbnail":720,"represent":75,"url":721,"type":76,"layoutType":27,"contentType":27,"publicationTime":722,"isUnlisted":12,"isPublished":13,"statistics":723,"categoryId":156,"relations":724,"status":63},687738,"Lễ hội văn hóa – tâm linh lớn nhất TP Hồ Chí Minh được chuẩn bị chu đáo\n","\u003Cp style=\"text-align: justify;\">Kinhtedothi - Lễ hội Rằm tháng Giêng năm 2026 trên địa bàn phường Thủ Dầu Một (TP Hồ Chí Minh), đặc biệt tại khu vực chùa Bà Thiên Hậu, đang được chính quyền địa phương triển khai công tác chuẩn bị một cách bài bản, đồng bộ. Mục tiêu đặt ra là bảo đảm lễ hội diễn ra an toàn, văn minh, trật tự, đúng quy định pháp luật, tạo điều kiện thuận lợi để người dân và du khách thập phương đến chiêm bái, sinh hoạt tín ngưỡng đầu Xuân.\u003C/p>\n\u003Cp>\u003C/p>","resources2025/1/users/195/1111-1772272540.jpg","/le-hoi-van-hoa-tam-linh-lon-nhat-tp-ho-chi-minh-duoc-chuan-bi-chu-dao.989797.html","2026-02-28T17:35:28.748148",{},{"url":721,"state":725,"states":726,"participants":732,"authors":734,"relatedArticles":736,"portals":740,"category":156,"categories":741,"scoringCategory":742,"embeddedElements":743},1218685,[727,728,729,730,731,725],1218651,1218658,1218662,1218666,1218681,[733],283779,[735],188,[737,738,739],987375,988486,962994,[28],[],63,{"files":744,"images":745},[],[746,747,748,749],155826,155827,155828,155830,{"id":751,"siteId":27,"sub":75,"title":752,"intro":753,"thumbnail":754,"represent":75,"url":755,"type":76,"layoutType":27,"contentType":27,"publicationTime":756,"isUnlisted":12,"isPublished":13,"statistics":757,"categoryId":156,"categoryIds":87,"eventIds":758,"relations":759,"status":63},687733,"Phát triển di sản Hội hát chèo tàu Tổng Gối thành sản phẩm công nghiệp văn hóa","\u003Cp style=\"text-align: justify;\">Kinhtedothi – Hội hát chèo tàu Tổng Gối, xã Ô Diên được ghi danh là di sản văn hóa phi vật thể quốc gia là cơ hội để địa phương nâng tầm giá trị, đầu tư có chiều sâu, trở thành một sản phẩm của công nghiệp văn hóa, mang lại giá trị kinh tế xanh.\u003C/p>","resources2025/1/users/88/le-hoi-cheo-tau-tong-goi-3-1772266965.jpg","/phat-trien-di-san-hoi-hat-cheo-tau-tong-goi-thanh-san-pham-cong-nghiep-van-hoa.989771.html","2026-02-28T15:55:46.328266",{},"604,616",{"url":755,"state":760,"states":761,"participants":765,"tags":767,"authors":770,"locations":772,"relatedArticles":774,"portals":779,"category":156,"categories":780,"events":781,"scoringCategory":742,"embeddedElements":784},1218631,[762,763,764,760],1218625,1218626,1218630,[766],283771,[768,769],626358,626369,[771],29,[773],876,[775,776,777,778],714774,400220,989619,986803,[28],[539],[782,783],604,616,{"files":785,"images":786,"quotations":792},[],[787,788,789,790,791],155795,155796,155797,155798,155799,[793],5892,{"id":795,"siteId":27,"sub":75,"title":796,"intro":797,"thumbnail":798,"represent":75,"url":799,"type":76,"layoutType":27,"contentType":27,"publicationTime":800,"isUnlisted":12,"isPublished":13,"statistics":801,"categoryId":156,"relations":802,"status":63},687723,"Hải Phòng: khai mạc Tuần Văn hóa, Du lịch và Xúc tiến Thương mại Lễ hội Côn Sơn - Kiếp Bạc","\u003Cp>Kinhtedothi - Ngày 28/2, tại Khu di sản văn hóa thế giới Côn Sơn - Kiếp Bạc, UBND thành phố Hải Phòng tổ chức khai mạc Tuần Văn hóa, Du lịch và Xúc tiến Thương mại Lễ hội mùa Xuân Côn Sơn - Kiếp Bạc năm 2026.\u003C/p>\n\u003Cp>\u003C/p>","resources2025/1/users/69/3-1772252061.jpg","/hai-phong-khai-mac-tuan-van-hoa-du-lich-va-xuc-tien-thuong-mai-le-hoi-con-son-kiep-bac.989660.html","2026-02-28T13:44:37.24964",{},{"url":799,"state":803,"states":804,"participants":810,"authors":812,"relatedArticles":814,"portals":818,"category":156,"categories":819,"scoringCategory":117,"embeddedElements":820},1218576,[805,806,807,808,809,803],1218514,1218515,1218564,1218565,1218575,[811],283752,[813],116,[815,816,817],988850,988233,987045,[28],[],{"files":821,"images":822},[],[823,824,825,826],155722,155723,155724,155725,{"id":828,"siteId":27,"sub":75,"title":829,"intro":830,"thumbnail":831,"represent":75,"url":832,"type":76,"layoutType":27,"contentType":76,"publicationTime":833,"isUnlisted":12,"isPublished":13,"statistics":834,"categoryId":156,"relations":835,"status":63},687714,"Gala Tết Quê hương 2026: không gian nghệ thuật của ký ức, đoàn viên và sẻ chia","\u003Cp style=\"text-align: justify;\">Kinhtedothi - Gala Tết Quê hương 2026 với chủ đề “Tết An Vui”, do Cơ quan Báo và Phát thanh, Truyền hình Hà Nội và Công ty CP Quảng cáo Truyền thông Oscar phối hợp tổ chức, được bảo trợ thông tin bởi Tạp chí Gia Đình Việt Nam là không gian nghệ thuật đặc biệt nơi ký ức Tết xưa gặp gỡ nhịp sống hôm nay, lan tỏa tinh thần đoàn kết và hơi ấm tình người.\u003C/p>\n\u003Cp>\u003C/p>","resources2025/1/users/75/thu-thuy-1772246266.JPG","/gala-tet-que-huong-2026-khong-gian-nghe-thuat-cua-ky-uc-doan-vien-va-se-chia.989630.html","2026-02-28T11:13:00",{},{"url":832,"state":836,"states":837,"participants":845,"tags":847,"authors":849,"relatedArticles":851,"portals":855,"category":156,"categories":856,"scoringCategory":622,"embeddedElements":857},1218508,[838,839,840,841,842,843,844,836],1218484,1218485,1218486,1218489,1218497,1218501,1218507,[846],283748,[848],626368,[850],479,[852,853,854],989488,989471,985089,[28],[],{"files":858,"images":859},[],[860,861,862,863,864,865,866,867,868,869,870,871,872],155692,155693,155694,155695,155696,155697,155698,155699,155700,155701