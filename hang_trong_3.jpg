="button cursor-pointer"><svg width="9" height="16" viewBox="0 0 9 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M8.51172 7.88281C8.72266 8.09375 8.72266 8.48047 8.51172 8.69141L1.76172 15.4414C1.55078 15.6523 1.16406 15.6523 0.953125 15.4414C0.742188 15.2305 0.742188 14.8438 0.953125 14.6328L7.31641 8.26953L0.953125 1.94141C0.742188 1.73047 0.742188 1.34375 0.953125 1.13281C1.16406 0.921875 1.55078 0.921875 1.76172 1.13281L8.51172 7.88281Z" fill="#BBBBBB"></path></svg></span></div></div><span></span></div></div></div></div><div class="section_item section-item section_1809_item_4" data-v-7f52812d><div class="h-full" data-v-7f52812d><div id="component_1989" label="Cùng chuyên mục" template="Article_Category" dataloading="Eager" useexclusion="true" data-component-id="collection_category_details_ktdt" data-loaded="false" data-loading="false" type="COMPONENT" code="collection_category_details_ktdt" taxonomy="Details" loading="false"><span></span><div class="collection collection-container border-custom overflow-hidden"><!--[--><article taxonomy="Cards" template="Article" data-loaded="false" data-loading="false" loading="false"><div class="article basic-article border-custom"><div class="article-thumbnail"><a href="/le-hoi-van-hoa-tam-linh-lon-nhat-tp-ho-chi-minh-duoc-chuan-bi-chu-dao.989797.html" class=""><img loading="auto" class="object-fit-cover" src="https://resource.kinhtedothi.vn/resources2025/1/users/195/1111-1772272540.jpg?w=480&amp;h=320&amp;q=80" alt="Lễ hội văn hóa – tâm linh lớn nhất TP Hồ Chí Minh được chuẩn bị chu đáo
"></a></div><div class="basic-article_content"><!----><h3 class="article-title"><a href="/le-hoi-van-hoa-tam-linh-lon-nhat-tp-ho-chi-minh-duoc-chuan-bi-chu-dao.989797.html" class="">Lễ hội văn hóa – tâm linh lớn nhất TP Hồ Chí Minh được chuẩn bị chu đáo
</a></h3><div class="article-card-default__bottom"><span style="margin-right:5px;" class="article-time">28 Feb, 05:35 PM</span><a href="/le-hoi-van-hoa-tam-linh-lon-nhat-tp-ho-chi-minh-duoc-chuan-bi-chu-dao.989797.html" class=""></a></div><p class="mb-0 article-intro">Kinhtedothi - Lễ hội Rằm tháng Giêng năm 2026 trên địa bàn phường Thủ Dầu Một (TP Hồ Chí Minh), đặc biệt tại khu vực chùa Bà Thiên Hậu, đang được chính quyền địa phương triển khai công tác chuẩn bị một cách bài bản, đồng bộ. Mục tiêu đặt ra là bảo đảm lễ hội diễn ra an toàn, văn minh, trật tự, đúng quy định pháp luật, tạo điều kiện thuận lợi để người dân và du khách thập phương đến chiêm bái, sinh hoạt tín ngưỡng đầu Xuân.
</p></div></div></article><article taxonomy="Cards" template="Article" data-loaded="false" data-loading="false" loading="false"><div class="article basic-article border-custom"><div class="article-thumbnail"><a href="/phat-trien-di-san-hoi-hat-cheo-tau-tong-goi-thanh-san-pham-cong-nghiep-van-hoa.989771.html" class=""><img loading="auto" class="object-fit-cover" src="https://resource.kinhtedothi.vn/resources2025/1/users/88/le-hoi-cheo-tau-tong-goi-3-1772266965.jpg?w=480&amp;h=320&amp;q=80" alt="Phát triển di sản Hội hát chèo tàu Tổng Gối thành sản phẩm công nghiệp văn hóa"></a></div><div class="basic-article_content"><!----><h3 class="article-title"><a href="/phat-trien-di-san-hoi-hat-cheo-tau-tong-goi-thanh-san-pham-cong-nghiep-van-hoa.989771.html" class="">Phát triển di sản Hội hát chèo tàu Tổng Gối thành sản phẩm công nghiệp văn hóa</a></h3><div class="article-card-default__bottom"><span style="margin-right:5px;" class="article-time">28 Feb, 03:55 PM</span><a href="/phat-trien-di-san-hoi-hat-cheo-tau-tong-goi-thanh-san-pham-cong-nghiep-van-hoa.989771.html" class=""></a></div><p class="mb-0 article-intro">Kinhtedothi – Hội hát chèo tàu Tổng Gối, xã Ô Diên được ghi danh là di sản văn hóa phi vật thể quốc gia là cơ hội để địa phương nâng tầm giá trị, đầu tư có chiều sâu, trở thành một sản phẩm của công nghiệp văn hóa, mang lại giá trị kinh tế xanh.</p></div></div></article><article taxonomy="Cards" template="Article" data-loaded="false" data-loading="false" loading="false"><div class="article basic-article border-custom"><div class="article-thumbnail"><a href="/hai-phong-khai-mac-tuan-van-hoa-du-lich-va-xuc-tien-thuong-mai-le-hoi-con-son-kiep-bac.989660.html" class=""><img loading="auto" class="object-fit-cover" src="https://resource.kinhtedothi.vn/resources2025/1/users/69/3-1772252061.jpg?w=480&amp;h=320&amp;q=80" alt="Hải Phòng: khai mạc Tuần Văn hóa, Du lịch và Xúc tiến Thương mại Lễ hội Côn Sơn - Kiếp Bạc"></a></div><div class="basic-article_content"><!----><h3 class="article-title"><a href="/hai-phong-khai-mac-tuan-van-hoa-du-lich-va-xuc-tien-thuong-mai-le-hoi-con-son-kiep-bac.989660.html" class="">Hải Phòng: khai mạc Tuần Văn hóa, Du lịch và Xúc tiến Thương mại Lễ hội Côn Sơn - Kiếp Bạc</a></h3><div class="article-card-default__bottom"><span style="margin-right:5px;" class="article-time">28 Feb, 01:44 PM</span><a href="/hai-phong-khai-mac-tuan-van-hoa-du-lich-va-xuc-tien-thuong-mai-le-hoi-con-son-kiep-bac.989660.html" class=""></a></div><p class="mb-0 article-intro">Kinhtedothi - Ngày 28/2, tại Khu di sản văn hóa thế giới Côn Sơn - Kiếp Bạc, UBND thành phố Hải Phòng tổ chức khai mạc Tuần Văn hóa, Du lịch và Xúc tiến Thương mại Lễ hội mùa Xuân Côn Sơn - Kiếp Bạc năm 2026.
</p></div></div></article><article taxonomy="Cards" template="Article" data-loaded="false" data-loading="false" loading="false"><div class="article basic-article border-custom"><div class="article-thumbnail"><a href="/gala-tet-que-huong-2026-khong-gian-nghe-thuat-cua-ky-uc-doan-vien-va-se-chia.989630.html" class=""><img loading="auto" class="object-fit-cover" src="https://resource.kinhtedothi.vn/resources2025/1/users/75/thu-thuy-1772246266.JPG?w=480&amp;h=320&amp;q=80" alt="Gala Tết Quê hương 2026: không gian nghệ thuật của ký ức, đoàn viên và sẻ chia"></a></div><div class="basic-article_content"><!----><h3 class="article-title"><a href="/gala-tet-que-huong-2026-khong-gian-nghe-thuat-cua-ky-uc-doan-vien-va-se-chia.989630.html" class="">Gala Tết Quê hương 2026: không gian nghệ thuật của ký ức, đoàn viên và sẻ chia</a></h3><div class="article-card-default__bottom"><span style="margin-right:5px;" class="article-time">28 Feb, 11:13 AM</span><a href="/gala-tet-que-huong-2026-khong-gian-nghe-thuat-cua-ky-uc-doan-vien-va-se-chia.989630.html" class=""></a></div><p class="mb-0 article-intro">Kinhtedothi - Gala Tết Quê hương 2026 với chủ đề “Tết An Vui”, do Cơ quan Báo và Phát thanh, Truyền hình Hà Nội và Công ty CP Quảng cáo Truyền thông Oscar phối hợp tổ chức, được bảo trợ thông tin bởi Tạp chí Gia Đình Việt Nam là không gian nghệ thuật đặc biệt nơi ký ức Tết xưa gặp gỡ nhịp sống hôm nay, lan tỏa tinh thần đoàn kết và hơi ấm tình người.
</p></div></div></article><article taxonomy="Cards" template="Article" data-loaded="false" data-loading="false" loading="false"><div class="article basic-article border-custom"><div class="article-thumbnail"><a href="/da-nang-le-hoi-ba-chiem-son-don-bang-chung-nhan-du-san-van-hoa-phi-vat-the-quoc-gia.989499.html" class=""><img loading="auto" class="object-fit-cover" src="https://resource.kinhtedothi.vn/resources2025/1/users/153/z7570986986926-88701252ec92cdb7202888dd4bd0ab3c-1772202961.jpg?w=480&amp;h=320&amp;q=80" alt="Đà Nẵng: Lễ hội Bà Chiêm Sơn đón Bằng chứng nhận Du sản văn hóa phi vật thể quốc gia"></a></div><div class="basic-article_content"><!----><h3 class="article-title"><a href="/da-nang-le-hoi-ba-chiem-son-don-bang-chung-nhan-du-san-van-hoa-phi-vat-the-quoc-gia.989499.html" class="">Đà Nẵng: Lễ hội Bà Chiêm Sơn đón Bằng chứng nhận Du sản văn hóa phi vật thể quốc gia</a></h3><div class="article-card-default__bottom"><span style="margin-right:5px;" class="article-time">28 Feb, 06:59 AM</span><a href="/da-nang-le-hoi-ba-chiem-son-don-bang-chung-nhan-du-san-van-hoa-phi-vat-the-quoc-gia.989499.html" class=""></a></div><p class="mb-0 article-intro">Kinhtedothi – Tối 27/2, UBND xã Duy Xuyên (thành phố Đà Nẵng) đã đón Bằng chứng nhận Di sản văn hóa phi vật thể cấp quốc gia đối với Lễ hội Bà Chiêm Sơn.
</p></div></div></article><!--]--></div></div></div></div><div class="section_item section-item section_1809_item_5" data-v-7f52812d><div class="h-full" data-v-7f52812d><div id="component_1921" template="Article" dataloading="Silent" type="COMPONENT" code="page_detail-ktdt/com_tin-moi-bai-viet-thong-thuong" taxonomy="Collections" data-component-id="page_detail-ktdt/com_tin-moi-bai-viet-thong-thuong" data-loaded="false" data-loading="false" loading="false"><div class="label-component">Tin mới</div><div class="collection collection-container border-custom overflow-hidden"><!--[--><!--[--><div class="skeleton-wrapper first:mt-2 mb-2 last:mb-0"><!--[--><div class="skeleton-image" style="width:150px;height:80px;"></div><!--]--><!--[--><div class="skeleton-text"><!--[--><div class="skeleton-line long"></div><div class="skeleton-line long"></div><!--]--><div class="skeleton-line short"></div></div><!--]--></div><!--]--><!--[--><div class="skeleton-wrapper first:mt-2 mb-2 last:mb-0"><!--[--><div class="skeleton-image" style="width:150px;height:80px;"></div><!--]--><!--[--><div class="skeleton-text"><!--[--><div class="skeleton-line long"></div><div class="skeleton-line long"></div><!--]--><div class="skeleton-line short"></div></div><!--]--></div><!--]--><!--[--><div class="skeleton-wrapper first:mt-2 mb-2 last:mb-0"><!--[--><div class="skeleton-image" style="width:150px;height:80px;"></div><!--]--><!--[--><div class="skeleton-text"><!--[--><div class="skeleton-line long"></div><div class="skeleton-line long"></div><!--]--><div class="skeleton-line short"></div></div><!--]--></div><!--]--><!--[--><div class="skeleton-wrapper first:mt-2 mb-2 last:mb-0"><!--[--><div class="skeleton-image" style="width:150px;height:80px;"></div><!--]--><!--[--><div class="skeleton-text"><!--[--><div class="skeleton-line long"></div><div class="skeleton-line long"></div><!--]--><div class="skeleton-line short"></div></div><!--]--></div><!--]--><!--[--><div class="skeleton-wrapper first:mt-2 mb-